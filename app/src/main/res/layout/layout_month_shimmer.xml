<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="160dp">

        <!-- Shimmer Hero Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/hero_gradient"
                android:padding="18dp">

                <LinearLayout
                    android:id="@+id/shimmer_hero_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_hero_chip"
                        android:alpha="0.3" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_hero_chip"
                        android:alpha="0.3" />
                    <View
                        android:layout_width="50dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_hero_pill_positive"
                        android:alpha="0.3" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_below="@id/shimmer_hero_top"
                    android:gravity="end"
                    android:orientation="vertical">
                    <View
                        android:layout_width="92dp"
                        android:layout_height="44dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="8dp" />
                    <View
                        android:layout_width="60dp"
                        android:layout_height="12dp"
                        android:background="#33FFFFFF" />
                    <View
                        android:layout_width="80dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:background="#33FFFFFF" />
                </LinearLayout>

                <View
                    android:id="@+id/shimmer_hero_label"
                    android:layout_width="120dp"
                    android:layout_height="12dp"
                    android:layout_below="@id/shimmer_hero_top"
                    android:background="#33FFFFFF" />

                <View
                    android:layout_width="150dp"
                    android:layout_height="34dp"
                    android:layout_below="@id/shimmer_hero_label"
                    android:layout_marginTop="8dp"
                    android:background="#33FFFFFF" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Shimmer Asset Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="10dp">
            <View
                android:layout_width="100dp"
                android:layout_height="12dp"
                android:background="@color/divider" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@color/divider"
                android:alpha="0.3" />
        </LinearLayout>

        <!-- Shimmer Asset Items -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">
            <include layout="@layout/shimmer_item_asset" />
            <include layout="@layout/shimmer_item_asset" />
            <include layout="@layout/shimmer_item_asset" />
        </LinearLayout>

        <!-- Shimmer Liability Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="10dp">
            <View
                android:layout_width="100dp"
                android:layout_height="12dp"
                android:background="@color/divider" />
        </LinearLayout>

        <!-- Shimmer Liability Items -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">
            <include layout="@layout/shimmer_item_asset" />
            <include layout="@layout/shimmer_item_asset" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
