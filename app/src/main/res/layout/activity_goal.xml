<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/goal_activity_title"
            app:titleTextColor="@color/textPrimary"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/textPrimary"/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Current net worth reference -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/currentNetWorthCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#33FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:letterSpacing="0.12"
                        android:text="@string/goal_current_worth_label"
                        android:textAllCaps="true"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/currentNetWorth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textPrimary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Goal inputs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#33FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:letterSpacing="0.12"
                        android:text="@string/goal_section_label"
                        android:textAllCaps="true"
                        android:textColor="@color/colorAccent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black" />

                    <!-- 1-Year -->
                    <TextView
                        android:id="@+id/label1y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp" />

                    <EditText
                        android:id="@+id/goal1y"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/rate1y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/divider" />

                    <!-- 3-Year -->
                    <TextView
                        android:id="@+id/label3y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp" />

                    <EditText
                        android:id="@+id/goal3y"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/rate3y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/divider" />

                    <!-- 5-Year -->
                    <TextView
                        android:id="@+id/label5y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:textColor="@color/textSecondary"
                        android:textSize="10sp" />

                    <EditText
                        android:id="@+id/goal5y"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/rate5y"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveGoals"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/goal_save"
                        android:textColor="@color/textOnPrimary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        app:backgroundTint="@color/colorAccent"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
