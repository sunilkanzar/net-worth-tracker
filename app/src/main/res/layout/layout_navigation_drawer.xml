<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/navigation"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="@color/bg_elev"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <!-- ── Header ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="18dp">

        <!-- Goal section (when goal is set) -->
        <LinearLayout
            android:id="@+id/drawerGoalSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="8dp">

            <include layout="@layout/item_drawer_goal_minimal" android:id="@+id/drawerGoal1yRow" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <include layout="@layout/item_drawer_goal_minimal" android:id="@+id/drawerGoal3yRow" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <include layout="@layout/item_drawer_goal_minimal" android:id="@+id/drawerGoal5yRow" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />

        </LinearLayout>
    </LinearLayout>

    <!-- Hidden IDs kept for backward-compat with MainActivity binding checks -->
    <View android:id="@+id/drawerSetGoalSection" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/drawerHeaderDivider" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- Header border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Scrollable nav items ──────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <!-- OVERVIEW -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overview"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingStart="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:id="@+id/navMonthly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_overview"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/drawer_month"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSetGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_goal"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/drawer_goal"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- ANALYTICS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analytics"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingStart="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:id="@+id/navGraph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chart"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/drawer_graph"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAllocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_pie"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Allocation"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAssetTrend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_trends"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="@string/drawer_asset_trend"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- DATA MANAGEMENT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data Management"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingStart="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:id="@+id/navBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_backup"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Backup"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
                <ImageView
                    android:id="@+id/navBackupChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_4"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navBackupSubmenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="58dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/navCreateBackup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="10dp"
                    android:text="Create Backup"
                    android:textColor="@color/text_2"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/navRestoreBackup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="10dp"
                    android:text="Restore Backup"
                    android:textColor="@color/text_2"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navImportExport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_import_export"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Import/Export"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
                <ImageView
                    android:id="@+id/navImportExportChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_4"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navImportExportSubmenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="58dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/navShareExport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="10dp"
                    android:text="Export"
                    android:textColor="@color/text_2"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/navImportFile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="10dp"
                    android:text="@string/drawer_import"
                    android:textColor="@color/text_2"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- OTHER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Other"
                android:textColor="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:paddingStart="8dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp"/>

            <LinearLayout
                android:id="@+id/navPreferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_nav_icon">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/text_2"/>
                </FrameLayout>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:text="Settings"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Footer ─────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="16dp">

        <!-- User email (shown when signed in) -->
        <LinearLayout
            android:id="@+id/signedInLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/drawerAvatarContainer"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_drawer_avatar">
                <TextView
                    android:id="@+id/drawerAvatarText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="W"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:id="@+id/userEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_3"
                android:textSize="12sp"/>

            <ImageView
                android:id="@+id/signOut"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_logout"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"/>
        </LinearLayout>

        <!-- Sync to Drive -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/googleSignIn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sync to Drive"
            android:textAllCaps="false"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/bg_elev"
            app:cornerRadius="12dp"
            app:icon="@drawable/googleg_standard_color_18"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@null"
            app:strokeColor="@color/border_strong"
            app:strokeWidth="1dp"/>

    </LinearLayout>

</LinearLayout>
