<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/bg_elev">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage Note Tags"
        android:textColor="@color/text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/editNewTag"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="New tag (e.g. Buy)"
            android:textColor="@color/text"
            android:textColorHint="@color/text_4"
            android:textSize="14sp"
            android:background="@drawable/bg_note_textarea"
            android:padding="10dp"
            android:maxLines="1"
            android:inputType="text"/>

        <ImageButton
            android:id="@+id/btnAddTag"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/icon_plus"
            android:background="@drawable/bg_save_btn"
            app:tint="#FFFFFF"
            android:contentDescription="Add Tag"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTags"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/btnDone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="DONE"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
