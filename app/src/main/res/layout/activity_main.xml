<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- ── Goals Card (Conditional) ───────────────────── -->
        <View
            android:id="@+id/goalsDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="260dp"
            android:background="@color/divider"
            android:visibility="gone" />

        <!-- ── Month Navigation (Floating) ────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomAppBarCard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_elev"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/previousMonth"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/accent"
                    android:contentDescription="@string/previous_month" />

                <TextView
                    android:id="@+id/monthName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/nextMonth"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/accent"
                    android:contentDescription="@string/next_month" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Scrim ────────────────────────────────────────── -->
        <View
            android:id="@+id/fabScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="#80000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ── FAB Speed Dial ──────────────────────────────── -->
        <LinearLayout
            android:id="@+id/fabNoteContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="190dp"
            android:alpha="0"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:ignore="UseCompoundDrawables">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_fab_label"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Monthly Note"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_note"
                app:backgroundTint="#1F2937"
                app:fabCustomSize="44dp"
                app:tint="#FFFFFF"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MiniFAB"
                app:elevation="4dp"
                android:contentDescription="Monthly Note" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fabAssetContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="136dp"
            android:alpha="0"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:ignore="UseCompoundDrawables">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_fab_label"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Add Asset"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAsset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_plus"
                app:backgroundTint="#1F2937"
                app:fabCustomSize="44dp"
                app:tint="#FFFFFF"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MiniFAB"
                app:elevation="4dp"
                android:contentDescription="Add Asset" />
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/mainFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="70dp"
            android:src="@drawable/icon_plus"
            app:backgroundTint="@color/accent"
            app:fabCustomSize="56dp"
            app:tint="#FFFFFF"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.FAB"
            app:elevation="8dp"
            android:contentDescription="@string/menu" />

        <!-- ── New Asset Sheet ────────────────────────────── -->
        <include
            android:id="@+id/newAssetSheet"
            layout="@layout/layout_new_asset_sheet" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ── Navigation Drawer ────────────────────────────────── -->
    <include
        android:id="@+id/navigationView"
        layout="@layout/layout_navigation_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
