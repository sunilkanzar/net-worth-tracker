<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/colorPrimary"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="6dp">

                <!-- Row 1: menu | NET WORTH label + value | percent view -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/menu"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="6dp"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/icon_menu"
                        android:adjustViewBounds="true"
                        android:tint="#CCFFFFFF"
                        android:layout_centerVertical="true"/>

                    <com.kanzar.networthtracker.views.PercentView
                        android:id="@+id/percentView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@id/percentView"
                        android:layout_toEndOf="@id/menu"
                        android:layout_centerVertical="true"
                        android:paddingStart="12dp">

                        <TextView
                            android:textSize="9sp"
                            android:textColor="#80FFFFFF"
                            android:textAllCaps="true"
                            android:letterSpacing="0.18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="Net Worth"/>

                        <TextView
                            android:textStyle="bold"
                            android:textSize="32sp"
                            android:textColor="@color/textOnPrimary"
                            android:id="@+id/monthValue"
                            android:letterSpacing="-0.01"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                </RelativeLayout>

                <!-- Thin divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#30FFFFFF"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Row 2: change amount (colored) | prev month value -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="5dp">

                    <TextView
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:id="@+id/monthValueChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:textSize="12sp"
                        android:textColor="#99FFFFFF"
                        android:id="@+id/headerPrevValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <!-- Row 3: asset count only -->
                <TextView
                    android:textSize="11sp"
                    android:textColor="#99FFFFFF"
                    android:id="@+id/headerAssetCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Note preview (hidden until note exists) -->
                <TextView
                    android:textSize="12sp"
                    android:textColor="#AAFFFFFF"
                    android:id="@+id/monthCommentPreview"
                    android:visibility="gone"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── Asset list ──────────────────────────────────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/refreshLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/assetList"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/background"
                        android:clipToPadding="false"
                        android:paddingTop="8dp"
                        android:paddingBottom="90dp"/>

                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tutorial"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_alignTop="@id/refreshLayout"
                    app:cardBackgroundColor="@color/backgroundContent"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="12dp">
                    <include layout="@layout/activity_tutorial"/>
                </androidx.cardview.widget.CardView>

            </RelativeLayout>
        </LinearLayout>

        <!-- ── Bottom bar: month navigation ─────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottomAppBar"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:background="@color/surfaceElevated"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/previousMonth"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:src="@drawable/icon_arrow"
                android:rotation="90"
                android:tint="@color/colorAccent"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

            <TextView
                android:id="@+id/monthName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/nextMonth"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:src="@drawable/icon_arrow"
                android:rotation="270"
                android:tint="@color/colorAccent"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

        </LinearLayout>

        <!-- ── Scrim: tap to collapse FAB menu ───────────────────────── -->
        <View
            android:id="@+id/fabScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:visibility="gone"
            android:alpha="0"/>

        <!-- ── Speed-dial: Note mini-FAB ─────────────────────────────── -->
        <LinearLayout
            android:id="@+id/fabNoteContainer"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="196dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:alpha="0">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/surfaceElevated"
                app:cardCornerRadius="6dp"
                app:cardElevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Monthly Note"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_comment"
                app:fabSize="mini"
                app:backgroundTint="@color/surfaceElevated"
                app:tint="@color/colorAccent"/>

        </LinearLayout>

        <!-- ── Speed-dial: Asset mini-FAB ────────────────────────────── -->
        <LinearLayout
            android:id="@+id/fabAssetContainer"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="136dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:alpha="0">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/surfaceElevated"
                app:cardCornerRadius="6dp"
                app:cardElevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Add Asset"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAsset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_plus"
                app:fabSize="mini"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@color/textOnPrimary"/>

        </LinearLayout>

        <!-- ── Main FAB (expandable trigger) ─────────────────────────── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/newAssetSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="68dp"
            android:src="@drawable/icon_plus"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/textOnPrimary"
            android:contentDescription="Add"/>

        <!-- ── Add / Edit Asset Form (bottom sheet card) ─────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/newAssetLayout"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="56dp"
            app:cardBackgroundColor="@color/surfaceElevated"
            app:cardElevation="24dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- Handle bar -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider"/>

                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/new_asset_name_hint"/>

                <AutoCompleteTextView
                    android:id="@+id/newAssetName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="@color/textPrimary"
                    android:hint="@string/new_asset_name_hint"
                    android:inputType="textCapSentences"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">

                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/colorAccent"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/new_asset_value_hint"/>

                        <EditText
                            android:id="@+id/newAssetValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            android:textColor="@color/textPrimary"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp">

                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/colorAccent"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/new_asset_change_hint"/>

                        <EditText
                            android:id="@+id/newAssetChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            android:textColor="@color/textPrimary"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Save button inside form -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveAsset"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Save"
                    android:textSize="15sp"
                    android:textColor="@color/textOnPrimary"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/icon_save"
                    app:iconTint="@color/textOnPrimary"
                    app:iconGravity="textStart"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ── Navigation Drawer ─────────────────────────────────────────── -->
    <com.google.android.material.navigation.NavigationView
        android:layout_gravity="start"
        android:id="@+id/navigation"
        android:background="@color/backgroundContent"
        android:layout_width="280dp"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:gravity="center"
                android:id="@+id/goToWeb"
                android:background="@color/colorPrimary"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/textOnPrimary"
                    android:textStyle="bold"
                    android:letterSpacing="0.14"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_domain"
                    android:textAllCaps="true"/>

            </LinearLayout>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navMonthly"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/drawer_month"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navGraph"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_graph"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navAllocation"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_allocation"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navAssetTrend"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_asset_trend"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navExport"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_export"/>

            <TextView
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                android:id="@+id/navImport"
                android:background="?android:attr/selectableItemBackground"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drawer_import"/>

            <View
                android:background="@color/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.gms.common.SignInButton
                android:id="@+id/googleSignIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/signedInLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="4dp">

                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/textSecondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="@string/user_sign_in_as"/>

                <TextView
                    android:id="@+id/userEmail"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/signOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/user_sign_out"
                    android:textColor="@color/colorAccent"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/colorAccent"/>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
