<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@color/colorPrimary"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="6dp">

                <!-- Row 1: menu | net worth + amount | right column (percent + spinner INVISIBLE) -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/menu"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="6dp"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/icon_menu"
                        android:adjustViewBounds="true"
                        app:tint="#CCFFFFFF"
                        android:layout_centerVertical="true"/>

                    <com.kanzar.networthtracker.views.PercentView
                        android:id="@+id/percentView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>

                    <!-- Center: label + amount, constrained between menu and right column -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/menu"
                        android:layout_toStartOf="@id/percentView"
                        android:layout_centerVertical="true"
                        android:paddingStart="12dp">

                        <TextView
                            android:textSize="9sp"
                            android:textColor="#80FFFFFF"
                            android:textAllCaps="true"
                            android:letterSpacing="0.18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"
                            android:text="Net Worth"/>

                        <TextView
                            android:id="@+id/monthValue"
                            android:textStyle="bold"
                            android:textColor="@color/textOnPrimary"
                            android:letterSpacing="-0.01"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMinTextSize="16sp"
                            app:autoSizeMaxTextSize="40sp"
                            app:autoSizeStepGranularity="1sp"
                            android:maxLines="1"/>

                    </LinearLayout>
                </RelativeLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#30FFFFFF"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Row 2, 3 and Note combined to use space efficiently -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp">

                    <LinearLayout
                        android:id="@+id/headerLeftInfo"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@+id/headerTrendContainer"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/monthValueChange"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/headerAssetCount"
                            android:textSize="11sp"
                            android:textColor="#99FFFFFF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <!-- Note preview -->
                        <TextView
                            android:id="@+id/monthCommentPreview"
                            android:textSize="12sp"
                            android:textColor="#AAFFFFFF"
                            android:visibility="gone"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="6dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:ellipsize="end"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/headerTrendContainer"
                        android:orientation="vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="end"
                        android:paddingStart="16dp">

                        <TextView
                            android:id="@+id/headerPrevValue"
                            android:textSize="11sp"
                            android:textColor="#99FFFFFF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>

                        <com.kanzar.networthtracker.views.MiniBarView
                            android:id="@+id/miniBarChart"
                            android:layout_width="110dp"
                            android:layout_height="44dp"/>

                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

            <!-- ── Asset list ──────────────────────────────────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/refreshLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/assetList"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/background"
                        android:clipToPadding="false"
                        android:paddingTop="8dp"
                        android:paddingBottom="90dp"/>

                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tutorial"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_alignTop="@id/refreshLayout"
                    app:cardBackgroundColor="@color/backgroundContent"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="12dp">
                    <include layout="@layout/activity_tutorial"/>
                </androidx.cardview.widget.CardView>

            </RelativeLayout>
        </LinearLayout>

        <!-- ── Bottom bar: month navigation ─────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottomAppBar"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:background="@color/surfaceElevated"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:id="@+id/previousMonth"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/colorAccent"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

            <TextView
                android:id="@+id/monthName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/nextMonth"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/colorAccent"
                android:padding="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>

        </LinearLayout>

        <!-- ── Scrim: tap to collapse FAB menu ───────────────────────── -->
        <View
            android:id="@+id/fabScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:visibility="gone"
            android:alpha="0"/>

        <!-- ── Speed-dial: Note mini-FAB ─────────────────────────────── -->
        <LinearLayout
            android:id="@+id/fabNoteContainer"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="196dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:alpha="0">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/surfaceElevated"
                app:cardCornerRadius="6dp"
                app:cardElevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Monthly Note"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_comment"
                app:fabSize="mini"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@color/textOnPrimary"/>

        </LinearLayout>

        <!-- ── Speed-dial: Asset mini-FAB ────────────────────────────── -->
        <LinearLayout
            android:id="@+id/fabAssetContainer"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="136dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:alpha="0">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@color/surfaceElevated"
                app:cardCornerRadius="6dp"
                app:cardElevation="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Add Asset"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"/>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAsset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/icon_plus"
                app:fabSize="mini"
                app:backgroundTint="@color/colorPrimary"
                app:tint="@color/textOnPrimary"/>

        </LinearLayout>

        <!-- ── Main FAB (expandable trigger) ─────────────────────────── -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/newAssetSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="68dp"
            android:src="@drawable/icon_plus"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/textOnPrimary"
            android:contentDescription="Add"/>

        <!-- ── Add / Edit Asset Form (bottom sheet card) ─────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/newAssetLayout"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="56dp"
            app:cardBackgroundColor="@color/surfaceElevated"
            app:cardElevation="24dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <!-- Handle bar -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:background="@color/divider"/>

                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/new_asset_name_hint"/>

                <AutoCompleteTextView
                    android:id="@+id/newAssetName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="@color/textPrimary"
                    android:hint="@string/new_asset_name_hint"
                    android:inputType="textCapSentences"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">

                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/colorAccent"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/new_asset_value_hint"/>

                        <EditText
                            android:id="@+id/newAssetValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            android:textColor="@color/textPrimary"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"/>

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/divider"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp">

                        <TextView
                            android:textSize="10sp"
                            android:textColor="@color/colorAccent"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/new_asset_change_hint"/>

                        <EditText
                            android:id="@+id/newAssetChange"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            android:textColor="@color/textPrimary"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Save button inside form -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveAsset"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Save"
                    android:textSize="15sp"
                    android:textColor="@color/textOnPrimary"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/icon_save"
                    app:iconTint="@color/textOnPrimary"
                    app:iconGravity="textStart"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ── Navigation Drawer ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/navigation"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/backgroundContent"
        android:clickable="true"
        android:fitsSystemWindows="true"
        android:focusable="true"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Goals progress (drawer) ──────────────────────── -->
                <LinearLayout
                    android:id="@+id/goalsCard"
                    android:visibility="gone"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="GOALS"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            android:textColor="@color/colorAccent"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/editGoals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:textColor="@color/colorAccent"
                            android:textSize="11sp"
                            android:padding="4dp"
                            android:background="?android:attr/selectableItemBackground"/>

                    </LinearLayout>

                    <!-- 1-Year: label | bar | % -->
                    <LinearLayout
                        android:id="@+id/goal1yRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/goal1yLabel"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="10sp"/>

                        <ProgressBar
                            android:id="@+id/goal1yBar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progressTint="@color/colorAccent"
                            android:progressBackgroundTint="@color/divider"/>

                        <TextView
                            android:id="@+id/goal1yPercent"
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <!-- 3-Year: label | bar | % -->
                    <LinearLayout
                        android:id="@+id/goal3yRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/goal3yLabel"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="10sp"/>

                        <ProgressBar
                            android:id="@+id/goal3yBar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progressTint="@color/colorAccent"
                            android:progressBackgroundTint="@color/divider"/>

                        <TextView
                            android:id="@+id/goal3yPercent"
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <!-- 5-Year: label | bar | % -->
                    <LinearLayout
                        android:id="@+id/goal5yRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/goal5yLabel"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textSecondary"
                            android:textSize="10sp"/>

                        <ProgressBar
                            android:id="@+id/goal5yBar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progressTint="@color/colorAccent"
                            android:progressBackgroundTint="@color/divider"/>

                        <TextView
                            android:id="@+id/goal5yPercent"
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/textPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:id="@+id/goalsDivider"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/header_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:paddingStart="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="8dp"
                    android:text="@string/drawer_section_overview"
                    android:textAllCaps="true"
                    android:textColor="@color/colorAccent"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/navGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_goals"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_trends"
                    app:drawableTint="@color/textSecondary" />

                <TextView
                    android:id="@+id/navMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_month"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_overview"
                    app:drawableTint="@color/textSecondary" />

                <TextView
                    android:id="@+id/navPreferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_preferences"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_settings"
                    app:drawableTint="@color/textSecondary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:paddingStart="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="@string/drawer_section_graphs"
                    android:textAllCaps="true"
                    android:textColor="@color/colorAccent"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/navGraph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_graph"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_chart"
                    app:drawableTint="@color/textSecondary" />

                <TextView
                    android:id="@+id/navAllocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_allocation"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_pie"
                    app:drawableTint="@color/textSecondary" />

                <TextView
                    android:id="@+id/navAssetTrend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_asset_trend"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_trends"
                    app:drawableTint="@color/textSecondary" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:paddingStart="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="@string/drawer_section_data"
                    android:textAllCaps="true"
                    android:textColor="@color/colorAccent"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/navExport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_export"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_export"
                    app:drawableTint="@color/textSecondary" />

                <!-- Import parent (toggles sub-menu) -->
                <TextView
                    android:id="@+id/navImport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_import"
                    android:textColor="@color/textPrimary"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_import"
                    app:drawableEndCompat="@drawable/ic_chevron_down"
                    app:drawableTint="@color/textSecondary" />

                <!-- Import sub-items (hidden by default) -->
                <LinearLayout
                    android:id="@+id/navImportSubmenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/navImportBackup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?android:attr/selectableItemBackground"
                        android:drawablePadding="16dp"
                        android:paddingStart="44dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/drawer_import_backup"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/navImportFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?android:attr/selectableItemBackground"
                        android:drawablePadding="16dp"
                        android:paddingStart="44dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/drawer_import_file"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/navClearAllData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:drawablePadding="16dp"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="@string/drawer_clear_all_data"
                    android:textColor="#CF6679"
                    android:textSize="15sp"
                    app:drawableStartCompat="@drawable/ic_delete"
                    app:drawableTint="#CF6679" />


            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/googleSignIn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="Sync to Drive"
            android:textAllCaps="false"
            android:textColor="@color/colorAccent"
            android:textSize="14sp"
            app:icon="@drawable/googleg_standard_color_18"
            app:iconTint="@null"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:strokeColor="@color/colorAccent"
            app:cornerRadius="8dp"/>

        <RelativeLayout
            android:id="@+id/signedInLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:visibility="gone"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/signOut"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="@string/user_sign_in_as"
                    android:textAllCaps="true"
                    android:textColor="@color/textSecondary"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/userEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"
                    android:ellipsize="end"
                    android:singleLine="true"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/signOut"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:src="@drawable/ic_logout"
                app:tint="@color/colorAccent"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/user_sign_out" />

        </RelativeLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
