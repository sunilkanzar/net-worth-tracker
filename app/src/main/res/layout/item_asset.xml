<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/assetCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_elev"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="14dp">

        <TextView
            android:id="@+id/assetLetter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_asset_letter"
            android:gravity="center"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="A" />

        <TextView
            android:id="@+id/assetName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            app:layout_constraintStart_toEndOf="@id/assetLetter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/assetSparkline"
            app:layout_constraintHorizontal_bias="0"
            tools:text="Asset Name" />

        <TextView
            android:id="@+id/assetWeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_3"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/assetName"
            app:layout_constraintTop_toBottomOf="@id/assetName"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="10%" />

        <TextView
            android:id="@+id/assetCompactValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_4"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/assetWeight"
            app:layout_constraintTop_toTopOf="@id/assetWeight"
            app:layout_constraintBottom_toBottomOf="@id/assetWeight"
            app:layout_constraintEnd_toStartOf="@id/assetSparkline"
            tools:text="₹1,000" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/assetSparkline"
            android:layout_width="48dp"
            android:layout_height="22dp"
            android:layout_marginHorizontal="8dp"
            app:layout_constraintEnd_toStartOf="@id/assetValue"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/assetValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="-0.02"
            android:gravity="end"
            android:minWidth="82dp"
            app:layout_constraintEnd_toStartOf="@id/assetChevron"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="₹1,000.00" />

        <TextView
            android:id="@+id/assetChangePercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="@color/positive"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            app:layout_constraintEnd_toEndOf="@id/assetValue"
            app:layout_constraintTop_toBottomOf="@id/assetValue"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="+5.0%" />

        <ImageView
            android:id="@+id/assetChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/tap_to_add"
            android:src="@drawable/ic_chevron_right"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="@color/text_4" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/assetValueContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:constraint_referenced_ids="assetValue,assetChangePercent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
