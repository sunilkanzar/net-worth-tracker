<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Shimmer Loader -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <include layout="@layout/layout_month_shimmer" />
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="160dp">

                <!-- ── Hero Card ─────────────────────────────────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/heroCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/hero_bg_start"
                    app:cardPreventCornerOverlap="false"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/hero_gradient"
                        android:padding="18dp"
                        android:clipToPadding="false">

                        <View
                            android:id="@+id/heroGradientView"
                            android:layout_width="200dp"
                            android:layout_height="140dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:layout_marginTop="-18dp"
                            android:layout_marginEnd="-18dp"
                            android:background="@drawable/bg_hero_radial" />

                        <!-- Top row -->
                        <LinearLayout
                            android:id="@+id/heroTopRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <FrameLayout
                                android:id="@+id/menu"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_hero_chip">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_menu_thin"
                                    app:tint="@color/hero_text"
                                    android:contentDescription="@string/menu" />
                            </FrameLayout>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <FrameLayout
                                android:id="@+id/privacyToggle"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_hero_chip">
                                <ImageView
                                    android:id="@+id/privacyIcon"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_eye_thin"
                                    app:tint="@color/hero_text"
                                    android:contentDescription="Toggle Privacy" />
                            </FrameLayout>

                            <LinearLayout
                                android:id="@+id/percentPill"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_hero_pill_positive"
                                android:gravity="center"
                                android:paddingHorizontal="9dp"
                                android:paddingVertical="4dp">

                                <ImageView
                                    android:id="@+id/percentArrow"
                                    android:layout_width="11dp"
                                    android:layout_height="11dp"
                                    android:layout_marginEnd="4dp"
                                    android:src="@drawable/ic_arrow_up_thin"
                                    app:tint="@color/positive"
                                    android:contentDescription="Trend" />

                                <TextView
                                    android:id="@+id/percentText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/positive"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    tools:text="+5.2%" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Right Stats Column (Graph + Assets/Liabs) -->
                        <LinearLayout
                            android:id="@+id/heroRightColumn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_below="@id/heroTopRow"
                            android:gravity="end"
                            android:orientation="vertical"
                            android:layout_marginTop="-12dp">

                            <com.kanzar.networthtracker.views.MiniBarView
                                android:id="@+id/miniBarChart"
                                android:layout_width="92dp"
                                android:layout_height="44dp"
                                android:layout_marginBottom="8dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ASSETS"
                                    android:textColor="@color/hero_text_muted"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-black"
                                    android:letterSpacing="0.08" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/heroAssetValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/hero_text"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:fontFamily="sans-serif-black"
                                        tools:text="₹1,50,000" />

                                    <TextView
                                        android:id="@+id/heroAssetCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:textColor="#80FFFFFF"
                                        android:textSize="10sp"
                                        tools:text="12" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="end"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LIABILITIES"
                                    android:textColor="@color/hero_text_muted"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-black"
                                    android:letterSpacing="0.08" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/heroLiabValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#FCA5A5"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:fontFamily="sans-serif-black"
                                        tools:text="₹25,000" />

                                    <TextView
                                        android:id="@+id/heroLiabCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="4dp"
                                        android:textColor="#80FFFFFF"
                                        android:textSize="10sp"
                                        tools:text="3" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Label -->
                        <TextView
                            android:id="@+id/heroTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/heroTopRow"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/heroRightColumn"
                            android:layout_marginEnd="12dp"
                            android:letterSpacing="0.12"
                            android:text="NET WORTH · APR 2026"
                            android:textColor="@color/hero_text_muted"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:textAllCaps="true" />

                        <!-- Main content row -->
                        <LinearLayout
                            android:id="@+id/heroMainRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/heroTitle"
                            android:layout_toStartOf="@id/heroRightColumn"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="4dp"
                            android:gravity="bottom"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="bottom"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/currencySymbol"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="2dp"
                                    android:layout_marginBottom="3dp"
                                    android:text="₹"
                                    android:textColor="@color/hero_text"
                                    android:alpha="0.7"
                                    android:textSize="22sp" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/monthValue"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="sans-serif-black"
                                    android:letterSpacing="-0.03"
                                    android:textColor="@color/hero_text"
                                    android:textSize="34sp"
                                    android:textStyle="bold"
                                    android:includeFontPadding="false"
                                    android:maxLines="1"
                                    app:autoSizeTextType="uniform"
                                    app:autoSizeMinTextSize="12sp"
                                    app:autoSizeMaxTextSize="34sp"
                                    app:autoSizeStepGranularity="1sp"
                                    tools:text="1,23,456" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="0dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/monthValueChangeArrow"
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:layout_marginEnd="6dp"
                                    android:src="@drawable/ic_arrow_up_thin"
                                    app:tint="@color/positive"
                                    android:contentDescription="Change arrow" />

                                <TextView
                                    android:id="@+id/monthValueChange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/positive"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"
                                    tools:text="+ ₹5,000" />

                                <TextView
                                    android:id="@+id/vsLastMonthLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="vs last month"
                                    android:textColor="#66FFFFFF"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/monthCommentPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/heroMainRow"
                            android:layout_toStartOf="@id/heroRightColumn"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-light"
                            android:maxLines="2"
                            android:textColor="@color/hero_text_muted"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Some monthly comment here..." />

                        <!-- Added PercentView for logic support -->
                        <com.kanzar.networthtracker.views.PercentView
                            android:id="@+id/percentView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <include
                    android:id="@+id/tutorial"
                    layout="@layout/layout_tutorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone" />

                <include
                    android:id="@+id/copyCardLayout"
                    layout="@layout/item_copy_all"
                    android:visibility="gone" />

                <!-- ── Assets Section ────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/assetHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/assetSectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ASSETS · 12"
                        style="@style/TextLabel" />

                    <ImageView
                        android:id="@+id/btnSort"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_sort"
                        app:tint="@color/text_3"
                        android:contentDescription="@string/sort" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/assetList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="16dp" />

                <!-- ── Not yet entered Section ───────────────────────────── -->
                <LinearLayout
                    android:id="@+id/placeholderHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/not_yet_entered"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/text_4"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:paddingVertical="8dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/placeholderList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <!-- ── Liabilities Section ───────────────────────────── -->
                <LinearLayout
                    android:id="@+id/liabHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/liabSectionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LIABILITIES · 3"
                        style="@style/TextLabel" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/liabList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
