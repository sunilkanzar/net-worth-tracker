<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_elev"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="14dp">

        <View
            android:id="@+id/shimmer_letter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_asset_letter"
            android:alpha="0.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <View
            android:id="@+id/shimmer_name"
            android:layout_width="100dp"
            android:layout_height="14dp"
            android:layout_marginStart="12dp"
            android:background="@color/divider"
            app:layout_constraintStart_toEndOf="@id/shimmer_letter"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmer_weight"
            android:layout_width="40dp"
            android:layout_height="10dp"
            android:layout_marginTop="6dp"
            android:background="@color/divider"
            app:layout_constraintStart_toStartOf="@id/shimmer_name"
            app:layout_constraintTop_toBottomOf="@id/shimmer_name"
            app:layout_constraintBottom_toBottomOf="parent" />

        <View
            android:id="@+id/shimmer_sparkline"
            android:layout_width="48dp"
            android:layout_height="22dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/divider"
            android:alpha="0.5"
            app:layout_constraintEnd_toStartOf="@id/shimmer_value"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <View
            android:id="@+id/shimmer_value"
            android:layout_width="80dp"
            android:layout_height="14dp"
            android:background="@color/divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmer_change"
            android:layout_width="40dp"
            android:layout_height="10dp"
            android:layout_marginTop="6dp"
            android:background="@color/divider"
            app:layout_constraintEnd_toEndOf="@id/shimmer_value"
            app:layout_constraintTop_toBottomOf="@id/shimmer_value"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
