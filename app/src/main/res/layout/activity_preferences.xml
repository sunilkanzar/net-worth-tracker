<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:elevation="6dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/pref_activity_title"
            app:titleTextColor="@color/textOnPrimary"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/textOnPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Preview Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/colorPrimary"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:letterSpacing="0.12"
                        android:text="@string/pref_preview_label"
                        android:textAllCaps="true"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/previewAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textOnPrimary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Currency Symbol Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/backgroundContent"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.12"
                        android:text="@string/pref_currency_label"
                        android:textAllCaps="true"
                        android:textColor="@color/colorAccent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgCurrency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbCurrencyNone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_none"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbCurrencyInr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_inr"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbCurrencyUsd"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_usd"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbCurrencyEur"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_eur"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbCurrencyGbp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_gbp"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbCurrencyJpy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_currency_jpy"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Number Format Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/backgroundContent"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.12"
                        android:text="@string/pref_format_label"
                        android:textAllCaps="true"
                        android:textColor="@color/colorAccent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgFormat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbFormatNone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_format_none"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbFormatIn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_format_in"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbFormatInt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_format_int"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Separator Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/backgroundContent"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:letterSpacing="0.12"
                        android:text="@string/pref_separator_label"
                        android:textAllCaps="true"
                        android:textColor="@color/colorAccent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgSeparator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbSepSpace"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_sep_space"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                        <RadioButton
                            android:id="@+id/rbSepComma"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="@string/pref_sep_comma"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp" />

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePrefs"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/pref_save"
                android:textColor="@color/textOnPrimary"
                android:textSize="15sp"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
