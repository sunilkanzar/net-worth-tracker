<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_elev"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/text"
            app:title="@string/pref_activity_title"
            app:titleTextColor="@color/text" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECTION: NUMBER -->
            <TextView
                style="@style/PreferenceSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_section_number" />

            <androidx.cardview.widget.CardView style="@style/PreferenceCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/rowCurrency"
                        layout="@layout/item_preference_row" />

                    <View style="@style/PreferenceDivider" />

                    <include
                        android:id="@+id/rowFormat"
                        layout="@layout/item_preference_row" />

                    <View style="@style/PreferenceDivider" />

                    <include
                        android:id="@+id/rowSeparator"
                        layout="@layout/item_preference_row" />

                    <View style="@style/PreferenceDivider" />

                    <include
                        android:id="@+id/rowFinancialYear"
                        layout="@layout/item_preference_row" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: APPEARANCE -->
            <TextView
                style="@style/PreferenceSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pref_section_appearance" />

            <androidx.cardview.widget.CardView style="@style/PreferenceCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/rowTheme"
                        layout="@layout/item_preference_row" />

                    <View style="@style/PreferenceDivider" />

                    <include
                        android:id="@+id/rowAccent"
                        layout="@layout/item_preference_row" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: DATA -->
            <TextView
                style="@style/PreferenceSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pref_section_data" />

            <androidx.cardview.widget.CardView style="@style/PreferenceCard">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include
                        android:id="@+id/rowBackup"
                        layout="@layout/item_preference_row" />

                    <View style="@style/PreferenceDivider" />

                    <include
                        android:id="@+id/rowReminders"
                        layout="@layout/item_preference_row" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: OTHER -->
            <TextView
                style="@style/PreferenceSectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pref_section_other" />

            <androidx.cardview.widget.CardView style="@style/PreferenceCard">

                <include
                    android:id="@+id/rowClearAll"
                    layout="@layout/item_preference_row" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="@string/pref_app_version"
                android:textColor="@color/text_4"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
