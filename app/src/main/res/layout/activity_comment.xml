<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_elev">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@color/bg_elev">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_back_btn"
            android:src="@drawable/ic_chevron_left"
            android:scaleType="center"
            android:contentDescription="Back"
            style="@style/Widget.AppCompat.ImageButton"/>

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Note"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

        <LinearLayout
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_save_btn"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_check_thin"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Border under header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tag chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/chipRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Goal"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipPurchase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Purchase"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipSell"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Sell"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈 Profit Booking"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipLoss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📉 Loss Harvest"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipReinvest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄 Reinvest"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipChurning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎢 Churning"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipIncome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Income"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipDip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📉 Dip"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/chipMilestone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Milestone"
                    android:background="@drawable/bg_note_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_2"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Textarea -->
        <EditText
            android:id="@+id/monthComment"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_note_textarea"
            android:padding="14dp"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:hint="What changed this month?"
            android:textColorHint="@color/text_4"
            android:fontFamily="sans-serif"/>

        <!-- Character count -->
        <TextView
            android:id="@+id/charCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 characters"
            android:textColor="@color/text_4"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</LinearLayout>
