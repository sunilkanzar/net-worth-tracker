<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        android:elevation="4dp"
        app:title="Month Note"
        app:titleTextColor="@color/textOnPrimary"
        app:navigationIcon="@drawable/ic_keyboard_arrow_left_black_24dp"
        app:navigationIconTint="@color/textOnPrimary"
        app:menu="@menu/menu_note"/>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/monthComment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@null"
        android:padding="20dp"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:hint="Write a note for this month…"
        android:textColorHint="#55FFFFFF"/>

</LinearLayout>
