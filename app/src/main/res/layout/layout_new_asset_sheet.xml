<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newAssetLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
    app:behavior_hideable="true"
    app:behavior_peekHeight="0dp"
    app:behavior_skipCollapsed="false"
    app:behavior_fitToContents="true"
    app:behavior_expandedOffset="80dp"
    app:cardBackgroundColor="@color/sheet_bg"
    app:cardCornerRadius="28dp"
    app:cardElevation="32dp"
    app:strokeWidth="0dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:id="@+id/sheetHandle"
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_sheet_handle" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/sheetScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingBottom="100dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- Header Area -->
                <LinearLayout
                    android:id="@+id/sheetHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/sheetStepLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/accent"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            tools:text="EDIT · APRIL 2026" />

                        <TextView
                            android:id="@+id/sheetTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/sheet_text"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="-0.02"
                            android:layout_marginTop="2dp"
                            tools:text="Mutual fund" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveAssetHeader"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="4dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:icon="@drawable/icon_save"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="22dp"
                        app:iconTint="@color/accent"
                        app:rippleColor="@color/sheet_chip_bg"
                        android:visibility="visible" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/assetInitialCard"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="16dp"
                        app:cardBackgroundColor="@color/sheet_input_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <TextView
                            android:id="@+id/assetInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="#22D3EE"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            tools:text="M" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Edit Area (Visible in Peek) -->
                <LinearLayout
                    android:id="@+id/layoutEditForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp">

                    <!-- Asset Name (Only for New) -->
                    <LinearLayout
                        android:id="@+id/layoutAssetName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/labelAssetName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_asset_name"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <AutoCompleteTextView
                            android:id="@+id/newAssetName"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_input_v2"
                            android:hint="@string/new_asset_name_hint"
                            android:inputType="textCapSentences"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/sheet_text"
                            android:textColorHint="@color/sheet_text_dim"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:completionThreshold="1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/labelCurrentValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/label_current_value"
                        android:textColor="@color/sheet_text_muted"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_input_v2"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textColor="@color/sheet_text_dim"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/newAssetValue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="0"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/sheet_text"
                        android:textColorHint="@color/sheet_text_dim"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/newAssetValueFormatted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/sheet_text_dim"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:id="@+id/labelChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="CHANGE SINCE LAST MONTH"
                    android:textColor="@color/sheet_text_muted"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_v2"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textColor="@color/sheet_text_dim"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/newAssetChange"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:background="@null"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="@color/sheet_text"
                            android:textColorHint="@color/sheet_text_dim"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_segmented_control"
                        android:padding="3dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnPlus"
                            android:layout_width="46dp"
                            android:layout_height="match_parent"
                            app:cardBackgroundColor="@color/sheet_input_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:id="@+id/txtPlus"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/plus"
                                android:textColor="@color/accent"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnMinus"
                            android:layout_width="46dp"
                            android:layout_height="match_parent"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:id="@+id/txtMinus"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/minus"
                                android:textColor="@color/sheet_text_dim"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="16dp">

                        <TextView
                            android:id="@+id/pillSame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Same as last month"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

                <!-- Trend Area (Visible on Expand) -->
                <LinearLayout
                    android:id="@+id/layoutTrend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="0dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:background="@color/sheet_border"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PERFORMANCE TREND"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.08"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="125dp"
                            android:layout_height="wrap_content"
                            app:hintEnabled="false"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeColor="@color/sheet_border"
                            app:endIconTint="@color/sheet_text_muted">
                            <AutoCompleteTextView
                                android:id="@+id/sheetRangeDropdown"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:paddingHorizontal="10dp"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/sheet_text"
                                android:maxLines="1"
                                android:singleLine="true"
                                tools:text="Custom"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="240dp">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/sheetChart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/sheetCursorCard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|center_horizontal"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="4dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="@color/sheet_input_bg"
                            android:visibility="gone"
                            tools:visibility="visible">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:gravity="center_vertical">
                                <TextView
                                    android:id="@+id/sheetCursorDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/sheet_text_muted"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-black"
                                    android:textAllCaps="true"
                                    tools:text="MAY 24"/>
                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="12dp"
                                    android:background="@color/sheet_border"
                                    android:layout_marginHorizontal="8dp"/>
                                <TextView
                                    android:id="@+id/sheetCursorValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/sheet_text"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-black"
                                    tools:text="₹1.2L"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <!-- Advanced Stats -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AVERAGE"
                                android:textColor="@color/sheet_text_muted"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/sheetStatAvg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/sheet_text"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="₹0"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BEST MONTH"
                                android:textColor="@color/sheet_text_muted"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/sheetStatBest"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/positive"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="+0%"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VOLATILITY"
                                android:textColor="@color/sheet_text_muted"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/sheetStatVol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/positive"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="Low"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAGR (EST)"
                                android:textColor="@color/sheet_text_muted"
                                android:textSize="9sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/sheetStatCAGR"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/sheet_text"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                tools:text="0%"/>
                        </LinearLayout>
                    </GridLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

            <!-- Footer Buttons -->
            <LinearLayout
                android:id="@+id/sheetButtonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="28dp"
                android:paddingTop="12dp"
                android:background="@color/sheet_bg">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseSheet"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/action_close"
                android:textAllCaps="false"
                android:textColor="@color/sheet_text"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/sheet_chip_bg"
                app:cornerRadius="16dp"
                app:strokeColor="@color/sheet_border"
                app:strokeWidth="1.5dp"
                app:rippleColor="?attr/colorControlHighlight" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteAsset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.5"
                android:layout_marginStart="14dp"
                android:text="@string/menu_delete"
                android:textAllCaps="false"
                android:textColor="@color/textOnPrimary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/negative"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/textOnPrimary"
                app:rippleColor="?attr/colorControlHighlight"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAsset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.8"
                android:layout_marginStart="14dp"
                android:text="Save"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/accent"
                app:cornerRadius="16dp"
                app:icon="@drawable/icon_save"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/textOnPrimary"
                app:rippleColor="?attr/colorControlHighlight" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
</com.google.android.material.card.MaterialCardView>
