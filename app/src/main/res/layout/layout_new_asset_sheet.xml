<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/newAssetLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
    app:behavior_hideable="true"
    app:behavior_peekHeight="0dp"
    app:behavior_skipCollapsed="true"
    app:behavior_expandedOffset="80dp"
    app:cardBackgroundColor="@color/sheet_bg"
    app:cardCornerRadius="28dp"
    app:cardElevation="32dp"
    app:strokeWidth="0dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:id="@+id/sheetHandle"
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_sheet_handle" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/sheetStepLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/accent"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            tools:text="EDIT · APRIL 2026" />

                        <TextView
                            android:id="@+id/sheetTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/sheet_text"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="-0.02"
                            android:layout_marginTop="2dp"
                            tools:text="Mutual fund" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/assetInitialCard"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="16dp"
                        app:cardBackgroundColor="@color/sheet_input_bg"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <TextView
                            android:id="@+id/assetInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="#22D3EE"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black"
                            tools:text="M" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Form Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp">

                    <!-- Asset Name (Only for New) -->
                    <LinearLayout
                        android:id="@+id/layoutAssetName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:id="@+id/labelAssetName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_asset_name"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <AutoCompleteTextView
                            android:id="@+id/newAssetName"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_input_v2"
                            android:hint="@string/new_asset_name_hint"
                            android:inputType="textCapSentences"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/sheet_text"
                            android:textColorHint="@color/sheet_text_dim"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:completionThreshold="1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/labelCurrentValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/label_current_value"
                        android:textColor="@color/sheet_text_muted"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_input_v2"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:textColor="@color/sheet_text_dim"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/newAssetValue"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="0"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="@color/sheet_text"
                        android:textColorHint="@color/sheet_text_dim"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:id="@+id/newAssetValueFormatted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/sheet_text_dim"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:id="@+id/labelChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="CHANGE SINCE LAST MONTH"
                    android:textColor="@color/sheet_text_muted"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_v2"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textColor="@color/sheet_text_dim"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />

                        <EditText
                            android:id="@+id/newAssetChange"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:background="@null"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"
                            android:textColor="@color/sheet_text"
                            android:textColorHint="@color/sheet_text_dim"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="54dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_segmented_control"
                        android:padding="3dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnPlus"
                            android:layout_width="46dp"
                            android:layout_height="match_parent"
                            app:cardBackgroundColor="@color/sheet_input_bg"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:id="@+id/txtPlus"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/plus"
                                android:textColor="@color/accent"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnMinus"
                            android:layout_width="46dp"
                            android:layout_height="match_parent"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:id="@+id/txtMinus"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/minus"
                                android:textColor="@color/sheet_text_dim"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="16dp">

                        <TextView
                            android:id="@+id/pillSame"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Same as last month"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillPlus5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="+5%"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillMinus5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="-5%"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillPurchase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Purchase"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillSell"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Sell"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillProfit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Profit Booking"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillLoss"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Loss Harvest"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillReinvest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Reinvest"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/pillChurning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_pill_v2"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="9dp"
                            android:text="Churning"
                            android:textColor="@color/sheet_text_muted"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Footer Buttons -->
    <LinearLayout
        android:id="@+id/sheetButtonsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="28dp"
        android:paddingTop="12dp"
        android:background="@color/sheet_bg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSheet"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="@color/sheet_text"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            app:backgroundTint="@color/sheet_chip_bg"
            app:cornerRadius="16dp"
            app:strokeColor="@color/sheet_border"
            app:strokeWidth="1.5dp"
            app:rippleColor="?attr/colorControlHighlight" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAsset"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.8"
            android:layout_marginStart="14dp"
            android:text="Save entry"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            app:backgroundTint="@color/accent"
            app:cornerRadius="16dp"
            app:icon="@drawable/icon_save"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/textOnPrimary"
            app:rippleColor="?attr/colorControlHighlight" />
    </LinearLayout>
</LinearLayout>
</com.google.android.material.card.MaterialCardView>
