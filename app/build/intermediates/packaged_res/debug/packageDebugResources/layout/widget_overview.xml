<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/widgetLayout"
    android:background="#EE121218"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:textSize="11sp"
        android:textColor="#CC1A1508"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:ellipsize="end"
        android:gravity="center"
        android:textAllCaps="true"
        android:id="@+id/widgetHeader"
        android:background="#EED4AF37"
        android:padding="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lines="1"/>

    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/widgetEmpty"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/icon_widget_add"/>

        <TextView
            android:textSize="11sp"
            android:textColor="#AAF0EDE4"
            android:ellipsize="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_no_entries"
            android:lines="1"/>

    </LinearLayout>

    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/changeView"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:textSize="11sp"
            android:textColor="#80F0EDE4"
            android:ellipsize="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="@string/widget_growth"
            android:lines="1"/>

        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:id="@+id/widgetPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"/>

    </LinearLayout>

</LinearLayout>
